<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.ForgotPasswordPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,30,20,20" Spacing="20">

            <!-- Encabezado con Logos (UTN + Smart Biodiversity) -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,10">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Image Source="hoja_icono.png" HeightRequest="35"/>
                    <Label Text="Smart&#10;Biodiversity" FontSize="12" TextColor="Black" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="38"/>
            </Grid>

            <!-- Título Principal -->
            <VerticalStackLayout Spacing="5" Margin="0,10,0,10">
                <Label Text="Recuperar Contraseña" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="Black" 
                       HorizontalOptions="Center"/>
                <Label Text="Ingresa tu correo para enviarte el código de verificación" 
                       FontSize="13" 
                       TextColor="Gray" 
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- BLOQUE 1: Correo y Botón de Enviar -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Correo electrónico" FontSize="12" TextColor="Gray"/>

                <Border BackgroundColor="#F0F0F0" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12,5">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="👤" FontSize="16" VerticalOptions="Center" Margin="5,0"/>
                        <Entry x:Name="txtCorreoRecuperacion" 
                               Grid.Column="1" 
                               Placeholder="ejemplo@correo.com" 
                               Keyboard="Email" 
                               TextColor="Black" 
                               PlaceholderColor="Gray"/>
                    </Grid>
                </Border>

                <Button Text="Enviar Código" 
                        BackgroundColor="#E0E0E0" 
                        TextColor="Black" 
                        FontAttributes="Bold" 
                        CornerRadius="10" 
                        HeightRequest="45"
                        Clicked="OnEnviarCodigoClicked"/>
            </VerticalStackLayout>

            <!-- BLOQUE 2: Código de Verificación y Botones (Oculto al inicio) -->
            <VerticalStackLayout x:Name="PanelCodigoVerificacion" IsVisible="False" Spacing="15" Margin="0,10,0,0">

                <Label Text="Revisa tu correo e ingresa el código de 6 dígitos" 
                       FontSize="13" 
                       TextColor="Gray" 
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center"/>

                <Border BackgroundColor="#F0F0F0" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12,5">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="🔑" FontSize="16" VerticalOptions="Center" Margin="5,0"/>
                        <Entry x:Name="txtCodigoVerificacion" 
                               Grid.Column="1" 
                               Placeholder="123456" 
                               Keyboard="Numeric" 
                               MaxLength="6" 
                               TextColor="Black" 
                               PlaceholderColor="Gray"/>
                    </Grid>
                </Border>

                <!-- Botones Reenviar y Verificar -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">

                    <Button Grid.Column="0" 
                            Text="Reenviar código" 
                            BackgroundColor="#F0F0F0" 
                            TextColor="Black" 
                            CornerRadius="10" 
                            HeightRequest="45"
                            Clicked="OnReenviarCodigoClicked"/>

                    <Button Grid.Column="1" 
                            Text="Verificar" 
                            BackgroundColor="#E0E0E0" 
                            TextColor="Black" 
                            FontAttributes="Bold" 
                            CornerRadius="10" 
                            HeightRequest="45"
                            Clicked="OnVerificarCodigoClicked"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Enlace para Volver al Login -->
            <Label Text="← Volver al inicio de sesión" 
                   TextColor="Gray" 
                   HorizontalOptions="Center" 
                   Margin="0,20,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVolverLoginTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>