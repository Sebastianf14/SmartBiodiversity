<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="SmartBiodiversity.RegisterPage" BackgroundColor="White" Title="RegisterPage">

    <ScrollView>
        <VerticalStackLayout Padding="30,40,30,30" Spacing="15">

            <!-- ENCABEZADO -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Image Source="hoja_icono.png"
                       HeightRequest="35"
                       VerticalOptions="Center"/>

                    <Label Text="Smart&#10;Biodiversity"
                       VerticalOptions="Center"
                       FontSize="14"
                       TextColor="Black" />
                </HorizontalStackLayout>

                <Image Grid.Column="1"
                   Source="utn_logo.png"
                   HeightRequest="45"
                   HorizontalOptions="End"
                   VerticalOptions="Center"/>
            </Grid>

            <!-- TÍTULO -->
            <Label Text="Crea tu cuenta de&#10;Smart Biodiversity"
               FontSize="20"
               TextColor="Black"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,15"/>

            <!-- PANEL 1: FORMULARIO DE REGISTRO -->
            <VerticalStackLayout x:Name="PanelRegistro"
                             Spacing="15">

                <Label Text="Regístrate"
                   FontSize="16"
                   TextColor="Black"
                   FontAttributes="Bold"
                   Margin="0,0,0,5"/>

                <!-- NOMBRE -->
                <Border BackgroundColor="#EFEFEF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    HeightRequest="45">

                    <Grid ColumnDefinitions="Auto, *">

                        <Label Text="👤"
                           Grid.Column="0"
                           VerticalOptions="Center"
                           Margin="15,0"/>

                        <Entry x:Name="txtNombre"
                           Grid.Column="1"
                           Placeholder="Nombre Completo"
                           TextColor="Black"
                           BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- CORREO -->
                <Border BackgroundColor="#EFEFEF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    HeightRequest="45">

                    <Grid ColumnDefinitions="Auto, *">

                        <Label Text="✉️"
                           Grid.Column="0"
                           VerticalOptions="Center"
                           Margin="15,0"/>

                        <Entry x:Name="txtEmailReg"
                           Grid.Column="1"
                           Placeholder="Correo Electrónico"
                           Keyboard="Email"
                           TextColor="Black"
                           BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- CONTRASEÑA -->
                <Border BackgroundColor="#EFEFEF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    HeightRequest="45">

                    <Grid ColumnDefinitions="Auto, *">

                        <Label Text="🔒"
                           Grid.Column="0"
                           VerticalOptions="Center"
                           Margin="15,0"/>

                        <Entry x:Name="txtPasswordReg"
                           Grid.Column="1"
                           Placeholder="Contraseña"
                           IsPassword="True"
                           TextColor="Black"
                           BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- CONFIRMAR CONTRASEÑA -->
                <Border BackgroundColor="#EFEFEF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    HeightRequest="45">

                    <Grid ColumnDefinitions="Auto, *">

                        <Label Text="🔒"
                           Grid.Column="0"
                           VerticalOptions="Center"
                           Margin="15,0"/>

                        <Entry x:Name="txtConfirmPassword"
                           Grid.Column="1"
                           Placeholder="Confirmar Contraseña"
                           IsPassword="True"
                           TextColor="Black"
                           BackgroundColor="Transparent"/>
                    </Grid>
                </Border>

                <!-- BOTÓN PARA ENVIAR CÓDIGO -->
                <Button Text="ENVIAR CÓDIGO DE VERIFICACIÓN"
                    Clicked="OnEnviarCodigoClicked"
                    BackgroundColor="#E0E0E0"
                    TextColor="Gray"
                    FontAttributes="Bold"
                    CornerRadius="20"
                    HeightRequest="50"
                    Margin="0,20,0,0"/>

            </VerticalStackLayout>


            <!-- PANEL 2: VERIFICACIÓN DE CÓDIGO -->
            <VerticalStackLayout x:Name="PanelVerificacion"
                             Spacing="15"
                             IsVisible="False">

                <Label Text="Revisa tu correo"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="Black"/>

                <Label Text="Hemos enviado un código de 6 dígitos a tu correo electrónico."
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="Gray"
                   Margin="0,0,0,10"/>

                <Border BackgroundColor="#EFEFEF"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 10"
                    HeightRequest="50">

                    <Entry x:Name="txtCodigoVerificacion"
                       Placeholder="Ingresa el código"
                       Keyboard="Numeric"
                       MaxLength="6"
                       HorizontalTextAlignment="Center"
                       TextColor="Black"
                       BackgroundColor="Transparent"/>
                </Border>

                <Button Text="VERIFICAR Y CREAR CUENTA"
                    Clicked="OnVerificarYCrearClicked"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="20"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

                <Button Text="Reenviar código"
                    Clicked="OnReenviarCodigoClicked"
                    BackgroundColor="Transparent"
                    TextColor="#1976D2"
                    FontAttributes="Bold"
                    Margin="0,5,0,0"/>

            </VerticalStackLayout>


            <!-- VOLVER AL LOGIN -->
            <HorizontalStackLayout HorizontalOptions="Center"
                               Margin="0,10,0,0">

                <Label Text="¿Ya tienes una cuenta? "
                   FontSize="12"
                   TextColor="Gray" />

                <Label Text="Inicia Sesión aquí"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="Black">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoToLoginTapped" />
                    </Label.GestureRecognizers>

                </Label>
            </HorizontalStackLayout>


            <!-- SEPARADOR -->
            <BoxView HeightRequest="1"
                 Color="#E0E0E0"
                 Margin="0,20,0,15" />


            <!-- ICONOS -->
            <HorizontalStackLayout HorizontalOptions="Center"
                               Spacing="40">

                <Image Source="gmail_icono.png"
                   HeightRequest="35"/>

                <Image Source="outlook_icono.png"
                   HeightRequest="35"/>

            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>