<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.LoginPage"
             BackgroundColor="White">
    <ScrollView>
        <VerticalStackLayout Padding="30,50,30,30" Spacing="15">

            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Image Source="hoja_icono.png" HeightRequest="35" VerticalOptions="Center"/>
                    <Label Text="Smart&#10;Biodiversity" VerticalOptions="Center" FontSize="14" TextColor="Black" />
                </HorizontalStackLayout>

                <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="45" HorizontalOptions="End" VerticalOptions="Center"/>
            </Grid>

            <Label Text="Bienvenido a&#10;Smart Biodiversity" 
                   FontSize="20" 
                   TextColor="Black" 
                   HorizontalTextAlignment="Center" 
                   Margin="0,0,0,20"/>

            <Label Text="Iniciar Sesión" 
                   FontSize="16" 
                   TextColor="Black" 
                   FontAttributes="Bold"/>

            <Label Text="Correo electrónico" FontSize="12" TextColor="Gray"/>
            <Border BackgroundColor="#EFEFEF" StrokeThickness="0" StrokeShape="RoundRectangle 10" HeightRequest="45">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="👤" Grid.Column="0" VerticalOptions="Center" Margin="15,0"/>
                    <Entry x:Name="txtEmail" 
                           Grid.Column="1" 
                           Placeholder="ejemplo@correo.com" 
                           Keyboard="Email" 
                           TextColor="Black" 
                           BackgroundColor="Transparent"/>
                </Grid>
            </Border>

            <Label Text="Contraseña" FontSize="12" TextColor="Gray" Margin="0,10,0,0"/>
            <Border BackgroundColor="#EFEFEF" StrokeThickness="0" StrokeShape="RoundRectangle 10" HeightRequest="45">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="🔒" Grid.Column="0" VerticalOptions="Center" Margin="15,0"/>
                    <Entry x:Name="txtPassword" 
                           Grid.Column="1" 
                           Placeholder="••••••••" 
                           IsPassword="True" 
                           TextColor="Black" 
                           BackgroundColor="Transparent"/>
                </Grid>
            </Border>

            <Label Text="¿Olvidé mi contraseña?" 
             TextColor="Gray" 
             FontSize="12"
             HorizontalOptions="End">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOlvidePasswordTapped" />
                </Label.GestureRecognizers>
            </Label>

            <Button Text="INICIAR SESIÓN" 
                    Clicked="OnLoginClicked" 
                    BackgroundColor="#E0E0E0" 
                    TextColor="Gray" 
                    FontAttributes="Bold" 
                    CornerRadius="20" 
                    HeightRequest="50" 
                    Margin="0,20,0,0"/>

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
                <Label Text="¿No tienes una cuenta? " FontSize="12" TextColor="Gray" />
                <Label Text="Regístrate aquí" FontSize="12" FontAttributes="Bold" TextColor="Black">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoToRegisterTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,30,0,20" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="40">
                <Image Source="gmail_icono.png" HeightRequest="35"/>
                <Image Source="outlook_icono.png" HeightRequest="35"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>