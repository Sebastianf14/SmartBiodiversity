<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.MainPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30,50,30,30" Spacing="15">

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                <Image Source="hoja_icono.png" HeightRequest="40" />
                <Label Text="Smart&#10;Biodiversity" VerticalOptions="Center" FontSize="16" TextColor="Black" />
                <Image Source="utn_logo.png" HeightRequest="40" />
            </HorizontalStackLayout>

            <Label Text="Bienvenido a&#10;Smart Biodiversity" 
                   FontSize="22" 
                   HorizontalTextAlignment="Center" 
                   TextColor="Black"
                   Margin="0,20,0,20"/>

            <Label Text="Iniciar Sesión" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="Black"/>

            <Label Text="Correo electrónico" TextColor="Gray" FontSize="14" />
            <Border Stroke="Transparent" BackgroundColor="#F0F0F0" Padding="10,0" StrokeShape="RoundRectangle 10">
                <Entry Placeholder="ejemplo@correo.com" 
                       Keyboard="Email" 
                       TextColor="Black" 
                       BackgroundColor="Transparent"/>
            </Border>

            <Label Text="Contraseña" TextColor="Gray" FontSize="14" Margin="0,10,0,0"/>
            <Border Stroke="Transparent" BackgroundColor="#F0F0F0" Padding="10,0" StrokeShape="RoundRectangle 10">
                <Entry Placeholder="••••••••" 
                       IsPassword="True" 
                       TextColor="Black" 
                       BackgroundColor="Transparent"/>
            </Border>

            <Label Text="¿Olvidé mi contraseña?" 
                   HorizontalOptions="End" 
                   FontSize="12" 
                   TextColor="Gray" 
                   TextDecorations="Underline"/>

            <Button Text="INICIAR SESIÓN" 
                    Clicked="OnLoginClicked"
                    CornerRadius="25" 
                    BackgroundColor="#E0E0E0" 
                    TextColor="Gray" 
                    FontAttributes="Bold" 
                    Margin="0,20,0,0"
                    HeightRequest="50"/>
            <Label Text="Regístrate aquí" FontSize="12" FontAttributes="Bold" TextColor="Black">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGoToRegisterTapped" />
                </Label.GestureRecognizers>
            </Label>

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,10,0,0">
                <Label Text="¿No tienes una cuenta? " FontSize="12" TextColor="Gray" />
                <Label Text="Regístrate aquí" FontSize="12" FontAttributes="Bold" TextColor="Black" />
            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="30" Margin="0,40,0,0">
                <Image Source="gmail_icono.png" HeightRequest="30"/>
                <Image Source="outlook_icono.png" HeightRequest="30"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
