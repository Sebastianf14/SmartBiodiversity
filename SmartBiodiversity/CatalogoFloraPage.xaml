<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.CatalogoFloraPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,30,20,20" Spacing="20">

                <!-- Header Logos -->
                <Grid ColumnDefinitions="*, Auto">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Image Source="hoja_icono.png" HeightRequest="30"/>
                        <Label Text="Smart&#10;Biodiversity" FontSize="12" TextColor="Black" />
                    </HorizontalStackLayout>
                    <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="35"/>
                </Grid>

                <!-- Título -->
                <Label Text="Catálogo de Flora" FontSize="20" FontAttributes="Bold" TextColor="Black"/>

                <!-- Lista de Especies -->
                <CollectionView x:Name="listaFlora">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#E0E0E0" 
                                    StrokeThickness="0" 
                                    StrokeShape="RoundRectangle 12" 
                                    Padding="15,10" 
                                    Margin="0,0,0,12">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Image Grid.Column="0" Source="{Binding ImagenUrl}" HeightRequest="50" WidthRequest="50" Aspect="AspectFit"/>
                                    <Label Grid.Column="1" Text="{Binding Nombre}" TextColor="Black" FontAttributes="Bold" VerticalOptions="Center" Margin="15,0,0,0"/>
                                    <Label Grid.Column="2" Text="Detalle" TextColor="Black" VerticalOptions="Center"/>
                                </Grid>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnDetalleTapped" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Barra Inferior -->
        <Border Grid.Row="1" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="0,10,0,15" Margin="-2,0,-2,-2">
            <Grid ColumnDefinitions="*, *, *, *">

                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Image Source="inicio_icono.png" HeightRequest="25"/>
                    <Label Text="Inicio" FontSize="12" TextColor="#2E7D32" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInicioTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Image Source="mapa_icono.png" HeightRequest="25"/>
                    <Label Text="Mapa" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Image Source="identificar_icono.png" HeightRequest="25"/>
                    <Label Text="Identificar" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                    <Image Source="perfil_icono.png" HeightRequest="25"/>
                    <Label Text="Perfil" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>