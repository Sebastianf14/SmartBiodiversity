<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.MapaPage"
             Title="MapaPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,30,20,10">
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Image Source="hoja_icono.png" HeightRequest="30"/>
                <Label Text="Smart&#10;Biodiversity" FontSize="12" TextColor="Black" />
            </HorizontalStackLayout>
            <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="35"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,10,20,20" Spacing="15">

                <Label Text="Mapa UTN campus el Olivo" FontSize="22" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"/>

                <Border Stroke="#BDBDBD" StrokeThickness="1" StrokeShape="RoundRectangle 10" BackgroundColor="#F5F5F5" HeightRequest="300">
                    <Image x:Name="imgMapa" Source="map1.png" Aspect="AspectFit">
                        <Image.GestureRecognizers>
                            <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                        </Image.GestureRecognizers>
                    </Image>
                </Border>

                <Label Text="Usa dos dedos para hacer zoom en el mapa" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center"/>

                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10" />

                <Label Text="Capacidad de Auditorios" FontSize="18" FontAttributes="Bold" TextColor="Black"/>

                <Grid ColumnDefinitions="30, *, *, 80" Padding="5" BackgroundColor="#E0E0E0">
                    <Label Grid.Column="0" Text="#" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center"/>
                    <Label Grid.Column="1" Text="FACULTAD" FontAttributes="Bold" TextColor="Black" FontSize="12" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="AUDITORIO" FontAttributes="Bold" TextColor="Black" FontSize="12" VerticalOptions="Center"/>
                    <Label Grid.Column="3" Text="CAPACIDAD" FontAttributes="Bold" TextColor="Black" FontSize="12" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                </Grid>

                <CollectionView x:Name="listaAuditorios">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="#EEEEEE" StrokeThickness="1" Padding="5">
                                <Grid ColumnDefinitions="30, *, *, 80">
                                    <Label Grid.Column="0" Text="{Binding Numero}" FontAttributes="Bold" TextColor="Black" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding Facultad}" TextColor="Black" FontSize="11" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding Nombre}" TextColor="Black" FontSize="11" VerticalOptions="Center"/>
                                    <Label Grid.Column="3" Text="{Binding Capacidad}" TextColor="Black" FontSize="11" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="0,10,0,15" Margin="-2,0,-2,-2">
            <Grid ColumnDefinitions="*, *, *, *">

                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Image Source="inicio_icono.png" HeightRequest="25"/>
                    <Label Text="Inicio" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInicioTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Image Source="mapa_icono.png" HeightRequest="25"/>
                    <Label Text="Mapa" FontSize="12" TextColor="#2E7D32" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Image Source="identificar_icono.png" HeightRequest="25"/>
                    <Label Text="Identificar" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                    <Image Source="perfil_icono.png" HeightRequest="25"/>
                    <Label Text="Perfil" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPerfilTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>