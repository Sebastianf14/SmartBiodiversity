<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.MapaPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,20,20,20" Spacing="15">

                <!-- Header Logos -->
                <Grid ColumnDefinitions="*, Auto">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Image Source="hoja_icono.png" HeightRequest="30"/>
                        <Label Text="Smart&#10;Biodiversity" FontSize="12" TextColor="Black" />
                    </HorizontalStackLayout>
                    <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="35"/>
                </Grid>

                <!-- Título -->
                <VerticalStackLayout Margin="0,5,0,0">
                    <Label Text="Mapa UTN campus El Olivo" FontSize="20" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center"/>
                    <Label Text="Explora las facultades y la biodiversidad registrada" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- CONTENEDOR DEL MAPA INTERACTIVO (LEAFLET.JS + OPENSTREETMAP) -->
                <Border BackgroundColor="#F5F5F5" 
                        Stroke="#CCCCCC" 
                        StrokeThickness="1" 
                        StrokeShape="RoundRectangle 15" 
                        HeightRequest="280">
                    <WebView x:Name="webMapView" HorizontalOptions="Fill" VerticalOptions="Fill" />
                </Border>

                <!-- RESUMEN TOTAL DE BIODIVERSIDAD -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5,0,0">
                    <Border Grid.Column="0" BackgroundColor="#E8F5E9" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="🌿 Total Flora" FontSize="12" TextColor="#2E7D32" FontAttributes="Bold"/>
                            <Label x:Name="lblTotalFlora" Text="0 especies" FontSize="16" TextColor="Black" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#E3F2FD" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="🐾 Total Fauna" FontSize="12" TextColor="#1565C0" FontAttributes="Bold"/>
                            <Label x:Name="lblTotalFauna" Text="0 especies" FontSize="16" TextColor="Black" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- TABLA DE BIODIVERSIDAD POR FACULTAD -->
                <Label Text="Biodiversidad por Facultad" FontSize="16" FontAttributes="Bold" TextColor="Black" Margin="0,10,0,0"/>

                <Border Stroke="#E0E0E0" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="0">
                    <VerticalStackLayout>
                        <!-- Cabecera de la Tabla -->
                        <Grid ColumnDefinitions="30, *, 65, 65" BackgroundColor="#EEEEEE" Padding="10,8">
                            <Label Grid.Column="0" Text="#" FontAttributes="Bold" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="1" Text="FACULTAD" FontAttributes="Bold" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="2" Text="FLORA" FontAttributes="Bold" FontSize="12" TextColor="#2E7D32" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3" Text="FAUNA" FontAttributes="Bold" FontSize="12" TextColor="#1565C0" HorizontalTextAlignment="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#E0E0E0"/>

                        <!-- FICA -->
                        <Grid ColumnDefinitions="30, *, 65, 65" Padding="10,8" BackgroundColor="White">
                            <Label Grid.Column="0" Text="1" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="1" Text="FICA (Ingeniería)" FontSize="12" TextColor="Black"/>
                            <Label x:Name="lblFicaFlora" Grid.Column="2" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                            <Label x:Name="lblFicaFauna" Grid.Column="3" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- FICAYA -->
                        <Grid ColumnDefinitions="30, *, 65, 65" Padding="10,8" BackgroundColor="#F9F9F9">
                            <Label Grid.Column="0" Text="2" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="1" Text="FICAYA (Agro / Amb)" FontSize="12" TextColor="Black"/>
                            <Label x:Name="lblFicayaFlora" Grid.Column="2" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                            <Label x:Name="lblFicayaFauna" Grid.Column="3" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- FECYT -->
                        <Grid ColumnDefinitions="30, *, 65, 65" Padding="10,8" BackgroundColor="White">
                            <Label Grid.Column="0" Text="3" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="1" Text="FECYT (Educación)" FontSize="12" TextColor="Black"/>
                            <Label x:Name="lblFecytFlora" Grid.Column="2" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                            <Label x:Name="lblFecytFauna" Grid.Column="3" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- FACAE -->
                        <Grid ColumnDefinitions="30, *, 65, 65" Padding="10,8" BackgroundColor="#F9F9F9">
                            <Label Grid.Column="0" Text="4" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="1" Text="FACAE (Administración)" FontSize="12" TextColor="Black"/>
                            <Label x:Name="lblFacaeFlora" Grid.Column="2" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                            <Label x:Name="lblFacaeFauna" Grid.Column="3" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- FACS -->
                        <Grid ColumnDefinitions="30, *, 65, 65" Padding="10,8" BackgroundColor="White">
                            <Label Grid.Column="0" Text="5" FontSize="12" TextColor="Black"/>
                            <Label Grid.Column="1" Text="FACS (Salud)" FontSize="12" TextColor="Black"/>
                            <Label x:Name="lblFacsFlora" Grid.Column="2" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                            <Label x:Name="lblFacsFauna" Grid.Column="3" Text="0" FontSize="12" TextColor="Black" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Barra de Navegación Inferior -->
        <Border Grid.Row="1" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="0,10,0,15" Margin="-2,0,-2,-2">
            <Grid ColumnDefinitions="*, *, *, *">

                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Image Source="inicio_icono.png" HeightRequest="25"/>
                    <Label Text="Inicio" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInicioTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Image Source="mapa_icono.png" HeightRequest="25"/>
                    <Label Text="Mapa" FontSize="12" TextColor="#2E7D32" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Image Source="identificar_icono.png" HeightRequest="25"/>
                    <Label Text="Identificar" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnIdentificarTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                    <Image Source="perfil_icono.png" HeightRequest="25"/>
                    <Label Text="Perfil" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPerfilTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>