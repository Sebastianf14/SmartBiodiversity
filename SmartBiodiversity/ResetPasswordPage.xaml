<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.ResetPasswordPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,30,20,20" Spacing="20">

            <!-- Encabezado con Logos -->
            <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,10">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Image Source="hoja_icono.png" HeightRequest="35"/>
                    <Label Text="Smart&#10;Biodiversity" FontSize="12" TextColor="Black" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="38"/>
            </Grid>

            <!-- Título -->
            <VerticalStackLayout Spacing="5" Margin="0,10,0,10">
                <Label Text="Nueva Contraseña" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="Black" 
                       HorizontalOptions="Center"/>
                <Label Text="Crea una contraseña segura para tu cuenta" 
                       FontSize="13" 
                       TextColor="Gray" 
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Campo 1: Nueva Contraseña -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Contraseña nueva" FontSize="12" TextColor="Gray"/>
                <Border BackgroundColor="#F0F0F0" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12,5">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="🔒" FontSize="16" VerticalOptions="Center" Margin="5,0"/>
                        <Entry x:Name="txtNuevaPassword" 
                               Grid.Column="1" 
                               IsPassword="True" 
                               Placeholder="••••••••" 
                               TextColor="Black" 
                               PlaceholderColor="Gray"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Campo 2: Confirmar Contraseña -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Confirmar contraseña" FontSize="12" TextColor="Gray"/>
                <Border BackgroundColor="#F0F0F0" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="12,5">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Text="🔒" FontSize="16" VerticalOptions="Center" Margin="5,0"/>
                        <Entry x:Name="txtConfirmarPassword" 
                               Grid.Column="1" 
                               IsPassword="True" 
                               Placeholder="••••••••" 
                               TextColor="Black" 
                               PlaceholderColor="Gray"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Botón Confirmar Cambio -->
            <Button Text="Confirmar cambio" 
                    BackgroundColor="#E0E0E0" 
                    TextColor="Black" 
                    FontAttributes="Bold" 
                    CornerRadius="10" 
                    HeightRequest="48"
                    Margin="0,15,0,0"
                    Clicked="OnConfirmarCambioClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>