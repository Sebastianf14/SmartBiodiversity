<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBiodiversity.DetalleItemPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,20,20,20" Spacing="15">

                <!-- Header Logos -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,10">
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Image Source="hoja_icono.png" HeightRequest="30"/>
                        <Label Text="Smart&#10;Biodiversity" FontSize="12" TextColor="Black" />
                    </HorizontalStackLayout>
                    <Image Grid.Column="1" Source="utn_logo.png" HeightRequest="35"/>
                </Grid>

                <!-- Botón Regresar -->
                <Label Text="← Regresar" TextColor="Gray" FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegresarTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- Nombre de la Especie -->
                <Label Text="{Binding Nombre}" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="Black" 
                       Margin="0,5,0,0"/>

                <!-- Imagen Real -->
                <Border BackgroundColor="#F5F5F5" 
                        StrokeThickness="0" 
                        StrokeShape="RoundRectangle 15" 
                        HeightRequest="220">
                    <Image Source="{Binding ImagenUrl}" Aspect="AspectFit"/>
                </Border>

                <!-- TARJETA DESCRIPCIÓN AMPLIADA -->
                <Border BackgroundColor="#E0F7FA" 
                        StrokeThickness="0" 
                        StrokeShape="RoundRectangle 12" 
                        Padding="20,18"
                        MinimumHeightRequest="180">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Descripción" 
                               FontAttributes="Bold" 
                               FontSize="16" 
                               TextColor="Black"/>

                        <!-- Etiqueta asignada con x:Name -->
                        <Label x:Name="lblDescripcion"
                               FontSize="14" 
                               TextColor="#333333"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Barra de Navegación Inferior -->
        <Border Grid.Row="1" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="White" Padding="0,10,0,15" Margin="-2,0,-2,-2">
            <Grid ColumnDefinitions="*, *, *, *">

                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                    <Image Source="inicio_icono.png" HeightRequest="25"/>
                    <Label Text="Inicio" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnInicioTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Image Source="mapa_icono.png" HeightRequest="25"/>
                    <Label Text="Mapa" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapaTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                    <Image Source="identificar_icono.png" HeightRequest="25"/>
                    <Label Text="Identificar" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnIdentificarTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                    <Image Source="perfil_icono.png" HeightRequest="25"/>
                    <Label Text="Perfil" FontSize="12" TextColor="Black" HorizontalOptions="Center"/>
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPerfilTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>